-- Conecte no banco keycloak
\c keycloak

-- Revoga e concede permissões do zero (mais forte)
REVOKE ALL ON SCHEMA public FROM keycloak;
GRANT ALL ON SCHEMA public TO keycloak;

-- Permissões no banco
GRANT ALL PRIVILEGES ON DATABASE keycloak TO keycloak;

-- Permissões em objetos existentes
GRANT ALL ON ALL TABLES IN SCHEMA public TO keycloak;
GRANT ALL ON ALL SEQUENCES IN SCHEMA public TO keycloak;
GRANT ALL ON ALL FUNCTIONS IN SCHEMA public TO keycloak;

-- Permissões padrão para o futuro
ALTER DEFAULT PRIVILEGES IN SCHEMA public 
    GRANT ALL ON TABLES TO keycloak;

ALTER DEFAULT PRIVILEGES IN SCHEMA public 
    GRANT ALL ON SEQUENCES TO keycloak;

ALTER DEFAULT PRIVILEGES IN SCHEMA public 
    GRANT ALL ON FUNCTIONS TO keycloak;

-- Torna o usuário owner do schema (mais garantido)
ALTER SCHEMA public OWNER TO keycloak;

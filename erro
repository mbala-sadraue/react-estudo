-- 1. Conceder privilégios completos no banco
GRANT ALL PRIVILEGES ON DATABASE keycloak TO keycloak;

-- 2. Conceder privilégios no schema public
GRANT ALL ON SCHEMA public TO keycloak;

-- 3. Conceder privilégios em todas as tabelas existentes (caso já tenha algo)
GRANT ALL ON ALL TABLES IN SCHEMA public TO keycloak;
GRANT ALL ON ALL SEQUENCES IN SCHEMA public TO keycloak;

-- 4. Para que futuras tabelas também tenham permissão automática
ALTER DEFAULT PRIVILEGES IN SCHEMA public GRANT ALL ON TABLES TO keycloak;
ALTER DEFAULT PRIVILEGES IN SCHEMA public GRANT ALL ON SEQUENCES TO keycloak;
